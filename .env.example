# ── App ──────────────────────────────────────────────
APP_NAME=Findjob
APP_ENV=development
# Requerido para OAuth con http://localhost en desarrollo
OAUTHLIB_INSECURE_TRANSPORT=1
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string-here-abc123
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# ── OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
# ── Karma / reportes ─────────────────────────────────
KARMA_MIN_TO_REPORT=50
COMPANY_WARNING_THRESHOLD=3
COMPANY_CROWD_VERIFY_THRESHOLD=3

# ── Database ─────────────────────────────────────────
# Local Ubuntu (peer auth via socket Unix, sin contraseña):
DATABASE_URL=postgresql+asyncpg://TU_USUARIO@/findjob?host=/var/run/postgresql
# Alternativa TCP (requiere usuario/contraseña en PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://findjob:findjob@localhost:5432/findjob
DATABASE_ECHO=false

# ── Redis / Celery ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Embeddings (Gemini API) ───────────────────────────
EMBEDDING_DIMENSIONS=768
EMBED_AFTER_SCRAPE=true
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_TASK_TYPE=RETRIEVAL_DOCUMENT
EMBEDDING_BATCH_SIZE=20
EMBEDDING_REQUEST_DELAY=0.5

# ── Gemini ───────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Scraping ─────────────────────────────────────────
# Usar un UA de Chrome real — Computrabajo bloquea bots obvios
SCRAPER_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
SCRAPER_REQUEST_DELAY=2.0
SCRAPER_HEADLESS=true
SCRAPER_MAX_RESULTS=30
# País de Computrabajo: ar, co, mx, pe, cl
COMPUTRABAJO_COUNTRY=ar
SCRAPER_FETCH_DETAILS=true
SCRAPER_DETAIL_DELAY=1.5